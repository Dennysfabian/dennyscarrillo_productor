---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const c = t('contact');
const today = new Date().toISOString().split('T')[0];
---

<section id="contact" class="relative py-20 sm:py-24 md:py-40 overflow-hidden">
  <!-- Ambient -->
  <div class="absolute inset-0 bg-gradient-to-b from-ink-950 via-ink-900 to-ink-950 -z-10"></div>
  <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full bg-gold-400/10 blur-[160px] pointer-events-none"></div>

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
      <!-- Left column -->
      <div class="lg:col-span-5">
        <div class="chip mb-6 reveal">
          <span class="w-1 h-1 rounded-full bg-gold-400"></span>
          {c.chip}
        </div>
        <h2 class="reveal font-display text-[clamp(2.25rem,5vw,4.5rem)] leading-[0.95] font-bold tracking-tight mb-8">
          {c.title.split(' ').map((w, i) => (
            <span class={`inline-block ${i === 0 ? '' : 'gradient-text'} mr-3`}>{w}</span>
          ))}
        </h2>
        <p class="reveal text-white/70 text-base md:text-lg leading-relaxed max-w-md mb-10">{c.subtitle}</p>

        <div class="reveal space-y-4">
          <div class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/50">{c.or}</div>
          <a href="mailto:booking@dennyscarrillo.com" class="inline-flex items-center gap-3 font-display text-xl md:text-2xl gold-text hover:opacity-80 transition-opacity" data-cursor="hover">
            booking@dennyscarrillo.com
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 8h14M8 1l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Socials: SC activo, resto placeholder a la espera de URLs -->
        <div class="reveal mt-12">
          <div class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40 mb-4">{c.soon}</div>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://soundcloud.com/dennyscarrillo"
              target="_blank"
              rel="noopener noreferrer"
              class="w-11 h-11 rounded-full border border-gold-500/40 bg-gold-500/10 grid place-items-center font-mono text-[10px] tracking-widest text-gold-300 hover:bg-gold-500/20 hover:border-gold-300 transition-colors"
              title="SoundCloud"
              data-cursor="hover"
            >SC</a>
            {['IG', 'MX', 'SP', 'YT'].map((s) => (
              <span class="w-11 h-11 rounded-full border border-white/10 bg-white/5 grid place-items-center font-mono text-[10px] tracking-widest text-white/40">
                {s}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Form Container -->
      <div class="lg:col-span-7 relative">
        <form
          id="booking-form"
          class="reveal relative rounded-[2rem] border border-white/10 bg-white/[0.03] backdrop-blur-xl p-8 md:p-12 transition-all duration-500"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value="73de69aa-af11-4f2a-af29-2e50d88cba51">
          
          <input type="hidden" name="redirect" value="https://bookings.dennyscarrillo.com/thank-you">

          <div class="absolute -top-px inset-x-10 h-[1px] bg-gradient-to-r from-transparent via-gold-500 to-transparent"></div>

          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div class="grid md:grid-cols-2 gap-6">
            <label class="flex flex-col gap-2">
              <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/50">{c.name}</span>
              <input type="text" name="name" required maxlength="80" autocomplete="name" class="field" />
            </label>
            <label class="flex flex-col gap-2">
              <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/50">{c.email}</span>
              <input type="email" name="email" required maxlength="120" autocomplete="email" class="field" />
            </label>
            <label class="flex flex-col gap-2 md:col-span-2">
              <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/50">{c.date}</span>
              <input type="date" name="date" class="field" min={today} />
            </label>
            <label class="flex flex-col gap-2 md:col-span-2">
              <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/50">{c.message}</span>
              <textarea name="message" rows="5" required maxlength="2000" class="field resize-none"></textarea>
            </label>
          </div>
          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4">
            <button type="submit" class="btn-primary w-full sm:w-auto transition-all duration-300 hover:opacity-90 hover:scale-[1.02]" data-cursor="hover">
              {c.send}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7h12M7 1l6 6-6 6"/></svg>
            </button>
            <p class="text-[11px] text-white/40 leading-relaxed">
              Tus datos están seguros y serán enviados directamente a nuestro equipo.
            </p>
          </div>
        </form>

        <!-- Success Message -->
        <div id="success-message" class="hidden flex-col items-center justify-center text-center rounded-[2rem] border border-gold-500/20 bg-white/[0.03] backdrop-blur-xl p-8 md:p-12 md:py-24 transition-opacity duration-500 opacity-0 absolute top-0 left-0 w-full h-full z-10">
          <div class="w-16 h-16 rounded-full bg-gold-500/10 text-gold-400 flex items-center justify-center mb-6">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 class="text-2xl md:text-4xl font-display font-bold gradient-text mb-4">¡Gracias!</h3>
          <p class="text-white/70 mb-8 max-w-sm text-base md:text-lg">
            Tu mensaje ha sido enviado correctamente. Nos pondremos en contacto contigo pronto.
          </p>
          <a href="/" class="btn-primary transition-all duration-300 hover:scale-[1.02]" data-cursor="hover">
            Volver al inicio
          </a>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form');
  const successMessage = document.getElementById('success-message');
  
  if (form && successMessage) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Feedback visual: Cambiar texto del botón
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.innerText = "Enviando...";
      submitBtn.disabled = true;

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: json
        });
        
        const result = await response.json();
        
        if (result.success) {
            // Ocultar formulario suavemente y mostrar mensaje de éxito
            form.style.opacity = '0';
            form.style.pointerEvents = 'none';
            successMessage.classList.remove('hidden');
            successMessage.classList.add('flex');
            
            // Pequeño delay para permitir que la clase 'flex' se aplique antes de la transición
            setTimeout(() => {
                successMessage.classList.remove('opacity-0');
            }, 50);
        } else {
            alert("Algo salió mal. Por favor intenta de nuevo.");
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
      } catch (error) {
          console.log(error);
          alert("Error de conexión.");
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  .field {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 14px 18px;
    color: #fff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15px;
    transition: border-color .3s ease, background .3s ease;
  }
  .field:focus {
    outline: none;
    border-color: rgba(230, 198, 122, 0.7);
    background: rgba(255, 255, 255, 0.06);
  }
  .field::-webkit-calendar-picker-indicator {
    filter: invert(1) opacity(0.5);
    cursor: pointer;
  }
</style>
